generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackedEvent {
  id          String   @id @default(cuid())
  eventName   String
  sessionId   String?
  createdAt   DateTime @default(now())
  source      String?
  ip          String?
  url         String?
  userAgent   String?
  utmCampaign String?
  utmMedium   String?
  utmSource   String?

  // ✅ Upgrade v1 additions (ADD ONLY)
  shop      String?
  visitorId String?
  eventId   String? @unique
  referrer  String?

  fbclid    String?
  gclid     String?
  ttclid    String?
  msclkid   String?

  @@index([createdAt])
  @@index([eventName])
  @@index([sessionId])
  @@index([utmSource])

  // ✅ Upgrade v1 indexes (ADD ONLY)
  @@index([shop])
  @@index([visitorId])
  @@index([eventId])
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

model Purchase {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  totalValue Float
  currency   String   @default("USD")

  // ✅ Upgrade v1 additions (ADD ONLY)
  shop      String?
  orderId   String? @unique
  visitorId String?
  sessionId String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  fbclid    String?
  gclid     String?
  ttclid    String?
  msclkid   String?

  @@index([createdAt])

  // ✅ Upgrade v1 indexes (ADD ONLY)
  @@index([shop])
  @@index([orderId])
  @@index([visitorId])
}

model AdSpendDaily {
  id       String   @id @default(cuid())
  date     DateTime
  spend    Float    @default(0)
  ad       String?
  adset    String?
  campaign String?
  platform String

  @@index([date])
  @@index([platform, date])
}

model TrackingSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  ga4Id     String?
  ga4Secret String?
  fbPixelId String?
  fbToken   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model MetaConnection {
  id          String    @id @default(cuid())
  shop        String    @unique
  accessToken String
  expiresAt   DateTime?
  adAccountId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shop])
}

model MetaCampaignDailyInsight {
  id            String   @id @default(cuid())
  shop          String
  date          DateTime
  campaignId    String
  campaignName  String?
  spend         Float    @default(0)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  purchases     Int      @default(0)
  purchaseValue Float    @default(0)
  raw           Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, date, campaignId], name: "shop_date_campaignId")
  @@index([shop, date])
  @@index([date])
}

model GoogleConnection {
  id           String    @id @default(cuid())
  shop         String    @unique
  accessToken  String
  refreshToken String?
  scope        String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  adCustomerId String?

  @@index([shop])
}