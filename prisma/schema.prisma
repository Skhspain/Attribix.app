// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String   @id
  shop          String
  state         String
  isOnline      Boolean  @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean  @default(false)
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)
}

model TrackedEvent {
  id         String   @id @default(cuid())
  eventName  String
  createdAt  DateTime @default(now())

  // Context
  url        String?
  ip         String?
  userAgent  String?

  // Attribution
  source      String?
  sessionId   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
}

model TrackingSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Connection + destinations
  fbPixelId  String?
  fbToken    String?
  ga4Id      String?
  ga4Secret  String?
}

model MetaConnection {
  id          String   @id @default(cuid())
  shop        String   @unique
  accessToken String
  tokenType   String?  // "bearer"
  expiresAt   DateTime?
  adAccountId String?  // e.g. "act_1234567890"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MetaCampaignDailyInsight {
  id          String   @id @default(cuid())
  shop        String
  date        DateTime
  adAccountId String
  campaignId  String
  campaignName String?
  spend       Float    @default(0)
  purchases   Int      @default(0)
  purchaseValue Float  @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop, date])
  @@index([shop, campaignId])
  @@unique([shop, date, campaignId])
}