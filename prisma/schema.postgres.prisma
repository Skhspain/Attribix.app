generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackedEvent {
  id          String   @id @default(cuid())
  eventName   String
  accountId   String?
  sessionId   String?
  createdAt   DateTime @default(now())
  source      String?
  ip          String?
  url         String?
  userAgent   String?
  utmCampaign String?
  utmMedium   String?
  utmSource   String?
  orderId     String?
  revenue     Float?
  currency    String?

  shop      String?
  visitorId String?
  eventId   String? @unique
  referrer  String?

  fbclid    String?
  gclid     String?
  ttclid    String?
  msclkid   String?

  fbp       String?
  fbc       String?
  host      String?
  origin    String?

  @@index([createdAt])
  @@index([eventName])
  @@index([sessionId])
  @@index([utmSource])
  @@index([shop])
  @@index([visitorId])
  @@index([eventId])
  @@index([fbclid])
  @@index([gclid])
  @@index([fbc])
  @@index([fbp])
  @@index([accountId])
  @@index([orderId])
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

model Purchase {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  totalValue Float
  currency   String   @default("USD")

  shop        String?
  orderId     String? @unique
  visitorId   String?
  sessionId   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  fbclid      String?
  gclid       String?
  ttclid      String?
  msclkid     String?

  fbp         String?
  fbc         String?
  referrer    String?
  landingPage String?
  country     String?
  city        String?

  @@index([createdAt])
  @@index([shop])
  @@index([orderId])
  @@index([visitorId])
  @@index([sessionId])
  @@index([fbclid])
  @@index([gclid])
  @@index([fbc])
  @@index([fbp])
}

// ─── Multi-touch attribution journey ─────────────────────────────────────────

model Touchpoint {
  id          String   @id @default(cuid())
  shop        String
  visitorId   String
  sessionId   String?
  channel     String
  utmSource   String?  @db.Text
  utmMedium   String?
  utmCampaign String?  @db.Text
  fbclid      String?  @db.Text
  gclid       String?  @db.Text
  ttclid      String?  @db.Text
  msclkid     String?  @db.Text
  referrer    String?  @db.Text
  landingPage String?  @db.Text
  touchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([shop, visitorId, sessionId])
  @@index([shop, visitorId, touchedAt])
  @@index([shop, channel])
  @@index([shop, touchedAt])
}

model PurchaseTouchpoint {
  id           String   @id @default(cuid())
  shop         String
  orderId      String
  visitorId    String?
  touchpointId String?
  position     Int
  totalSteps   Int
  channel      String
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  fbclid       String?  @db.Text
  gclid        String?  @db.Text
  revenue      Float
  currency     String   @default("USD")

  creditFirstTouch Float @default(0)
  creditLastTouch  Float @default(0)
  creditLinear     Float @default(0)
  creditTimeDecay  Float @default(0)

  touchedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([shop, orderId])
  @@index([shop, channel])
  @@index([shop, createdAt])
  @@index([visitorId])
}

model AdSpendDaily {
  id        String   @id @default(cuid())
  shop      String   @default("")
  date      DateTime
  platform  String
  campaign  String?
  adset     String?
  ad        String?
  spend     Float    @default(0)

  @@unique([shop, platform, date], name: "shop_platform_date")
  @@index([shop])
  @@index([date])
  @@index([platform, date])
}

model TrackingSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  ga4Id     String?
  ga4Secret String?
  fbPixelId String?
  fbToken   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackingKey     String?  @unique
  trackingEnabled Boolean  @default(true)
  pixelLastSeenAt DateTime?
  lastEventAt     DateTime?
  installedAt     DateTime?
  uninstalledAt   DateTime?

  attributionModel      String  @default("last_touch")
  attributionWindowDays Int     @default(7)
  leadWebhookToken      String?

  reviewsSeenAt    DateTime?
  leadsSeenAt      DateTime?
  newsletterSeenAt DateTime?

  @@index([shop])
  @@index([trackingKey])
  @@index([trackingEnabled])
}

model MetaConnection {
  id           String    @id @default(cuid())
  shop         String    @unique
  accessToken  String
  expiresAt    DateTime?
  adAccountId  String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([shop])
}

model MetaCampaignDailyInsight {
  id            String   @id @default(cuid())
  shop          String
  date          DateTime
  campaignId    String
  campaignName  String?
  objective     String?
  spend         Float    @default(0)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  purchases     Int      @default(0)
  purchaseValue Float    @default(0)
  raw           Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, date, campaignId], name: "shop_date_campaignId")
  @@index([shop, date])
  @@index([date])
}

model MetaAdDailyInsight {
  id            String   @id @default(cuid())
  shop          String
  date          DateTime
  campaignId    String
  campaignName  String?
  adSetId       String
  adSetName     String?
  adId          String
  adName        String?
  spend         Float    @default(0)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  ctr           Float    @default(0)
  cpc           Float    @default(0)
  purchases     Int      @default(0)
  purchaseValue Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, date, adId], name: "shop_date_adId")
  @@index([shop, date])
  @@index([campaignId])
}

model GoogleConnection {
  id            String    @id @default(cuid())
  shop          String    @unique
  accessToken   String
  refreshToken  String?
  expiresAt     DateTime?
  scope         String?
  adCustomerId  String?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shop])
}
// ─── Newsletter ───────────────────────────────────────────────────────────────

model NewsletterSettings {
  id                String  @id @default(cuid())
  shop              String  @unique
  fromName          String  @default("")
  fromEmail         String  @default("")
  replyTo           String  @default("")
  footerText        String  @default("")
  monthlyEmailLimit Int     @default(2500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  shop        String
  email       String
  firstName   String?
  lastName    String?
  status      String   @default("subscribed") // subscribed | unsubscribed
  source      String?  // "post_purchase" | "popup" | "manual" | "import"

  // Attribution at time of subscribe
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  gclid       String?
  fbclid      String?

  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([shop, email])
  @@index([shop, status])
  @@index([shop, createdAt])
  @@index([email])
}

model NewsletterCampaign {
  id          String   @id @default(cuid())
  shop        String
  name        String
  subject     String
  previewText String?
  fromName    String?
  fromEmail   String?
  replyTo     String?

  // Unlayer design JSON + rendered HTML
  designJson  Json?
  htmlContent String?  @db.Text

  status      String   @default("draft") // draft | scheduled | sending | sent | failed

  // Targeting / segmentation
  segmentFilter Json?  // { utmSource: "google", ... } etc.

  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int      @default(0)

  // Sending stats (populated after send)
  deliveredCount Int    @default(0)
  openCount      Int    @default(0)
  clickCount     Int    @default(0)
  bounceCount    Int    @default(0)
  unsubCount     Int    @default(0)

  // Revenue attribution
  revenueAttributed Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt])
  @@index([sentAt])
}

// ─── Lead Center ──────────────────────────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  shop      String
  email     String
  firstName String?
  lastName  String?
  phone     String?
  company   String?
  source    String?  // "newsletter_signup" | "contact_form" | "manual" | "import" | "meta_ad" | "google_ad"
  status    String   @default("new") // new | contacted | qualified | converted | lost
  notes     String?  @db.Text
  tags      String?  @db.Text  // comma-separated tags

  // Attribution
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  fbclid      String?
  gclid       String?
  referrer    String?

  convertedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, email])
  @@index([shop, status])
  @@index([shop, source])
  @@index([shop, createdAt])
  @@index([email])
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id              String    @id @default(cuid())
  shop            String
  productId       String
  productTitle    String?
  orderId         String?
  customerId      String?
  reviewerName    String
  reviewerEmail   String
  rating          Int
  title           String?
  body            String    @db.Text
  images          String?   @db.Text // JSON array of base64 data URLs
  status          String    @default("pending")
  verifiedPurchase Boolean  @default(false)
  reply           String?   @db.Text
  repliedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shop, productId, status])
  @@index([shop, status])
  @@index([shop, createdAt])
}

model ReviewSettings {
  shop               String  @id
  autoApprove        Boolean @default(false)
  sendRequestEmail   Boolean @default(true)
  requestDelayDays   Int     @default(7)
  emailSubject       String  @default("How was your order from {shop}?")
  emailBody          String  @db.Text @default("Hi {name},\n\nThank you for your recent order! We'd love to hear what you think.\n\nClick the link below to leave a quick review — it only takes a minute.\n\n{review_link}\n\nThank you!")
  discountEnabled    Boolean @default(false)
  discountType       String  @default("percentage")
  discountValue      Float   @default(10)
  discountExpiryDays Int     @default(30)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ReviewWidgetSettings {
  shop              String  @id
  primaryColor      String  @default("#4f46e5")
  starColor         String  @default("#f59e0b")
  backgroundColor   String  @default("#ffffff")
  borderColor       String  @default("#e5e7eb")
  layout            String  @default("list")
  showVerifiedBadge Boolean @default(true)
  showReviewerName  Boolean @default(true)
  showDate          Boolean @default(true)
  allowImages       Boolean @default(true)
  translateTo       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Automation Flows ─────────────────────────────────────────────────────────

model AutomationFlow {
  id          String   @id @default(cuid())
  shop        String
  name        String
  description String?
  trigger     String
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       AutomationStep[]
  enrollments AutomationEnrollment[]

  @@index([shop, trigger, enabled])
  @@index([shop])
}

model AutomationStep {
  id          String   @id @default(cuid())
  flowId      String
  position    Int
  delayDays   Int      @default(0)
  delayHours  Int      @default(0)
  subject     String   @default("")
  htmlContent String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flow        AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, position])
}

model AutomationEnrollment {
  id          String    @id @default(cuid())
  shop        String
  flowId      String
  email       String
  firstName   String?
  currentStep Int       @default(0)
  nextSendAt  DateTime?
  status      String    @default("active")
  triggeredBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  flow        AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, email])
  @@index([status, nextSendAt])
  @@index([shop])
}

// ─── Analytics: Segments & Dashboards ────────────────────────────────────────

model CustomerSegment {
  id        String   @id @default(cuid())
  shop      String
  name      String
  filters   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model CustomDashboard {
  id        String   @id @default(cuid())
  shop      String
  name      String
  widgets   String   @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model OrgStore {
  id        String   @id @default(cuid())
  orgId     String
  shop      String   @unique
  label     String?
  createdAt DateTime @default(now())

  @@index([orgId])
}

model Org {
  id          String   @id @default(cuid())
  name        String
  ownerEmail  String
  clerkUserId String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterImage {
  id        String   @id @default(cuid())
  shop      String
  filename  String
  mimeType  String
  data      String   @db.Text // base64-encoded image data
  size      Int
  createdAt DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
}

model StripeConnection {
  id           String    @id @default(cuid())
  shop         String    @unique
  apiKey       String
  accountName  String?
  currency     String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model TikTokConnection {
  id            String    @id @default(cuid())
  shop          String    @unique
  accessToken   String
  advertiserId  String?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([shop])
}

model TikTokCampaignDailyInsight {
  id              String   @id @default(cuid())
  shop            String
  date            DateTime
  campaignId      String
  campaignName    String?
  spend           Float    @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  conversionValue Float    @default(0)
  raw             String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([shop, date, campaignId])
  @@index([shop])
  @@index([shop, date])
}

model TikTokAdDailyInsight {
  id              String   @id @default(cuid())
  shop            String
  date            DateTime
  campaignId      String
  campaignName    String?
  adGroupId       String
  adGroupName     String?
  adId            String
  adName          String?
  spend           Float    @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  conversionValue Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([shop, date, adId])
  @@index([shop])
  @@index([shop, date])
}
