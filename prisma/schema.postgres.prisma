generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackedEvent {
  id          String   @id @default(cuid())
  eventName   String
  sessionId   String?
  createdAt   DateTime @default(now())
  source      String?
  ip          String?
  url         String?
  userAgent   String?
  utmCampaign String?
  utmMedium   String?
  utmSource   String?

  @@index([createdAt])
  @@index([eventName])
  @@index([sessionId])
  @@index([utmSource])
}

model Session {
  id            String   @id
  shop          String
  state         String
  isOnline      Boolean  @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean  @default(false)
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)

  @@index([shop])
}


model Purchase {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  totalValue Float
  currency   String   @default("USD")
}

model AdSpendDaily {
  id    String   @id @default(cuid())
  date  DateTime
  spend Float
}

model TrackingSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  ga4Id     String?
  ga4Secret String?
  fbPixelId String?
  fbToken   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MetaConnection {
  id          String   @id @default(cuid())
  shop        String   @unique
  accessToken String
  tokenType   String?  // "bearer"
  expiresAt   DateTime?
  adAccountId String?  // e.g. "act_1234567890"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MetaCampaignDailyInsight {
  id          String   @id @default(cuid())
  shop        String
  date        DateTime
  adAccountId String
  campaignId  String
  campaignName String?
  spend       Float    @default(0)
  purchases   Int      @default(0)
  purchaseValue Float  @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop, date])
  @@index([shop, campaignId])
  @@unique([shop, date, campaignId])
}
