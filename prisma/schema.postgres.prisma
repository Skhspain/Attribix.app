generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackedEvent {
  id          String   @id @default(cuid())
  eventName   String
  sessionId   String?
  createdAt   DateTime @default(now())
  source      String?
  ip          String?
  url         String?
  userAgent   String?
  utmCampaign String?
  utmMedium   String?
  utmSource   String?

  shop      String?
  visitorId String?
  eventId   String? @unique
  referrer  String?

  fbclid    String?
  gclid     String?
  ttclid    String?
  msclkid   String?

  fbp       String?
  fbc       String?
  host      String?
  origin    String?
  accountId String?

  @@index([createdAt])
  @@index([eventName])
  @@index([sessionId])
  @@index([utmSource])
  @@index([shop])
  @@index([visitorId])
  @@index([eventId])
  @@index([fbclid])
  @@index([gclid])
  @@index([fbc])
  @@index([fbp])
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

model Purchase {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  totalValue Float
  currency   String   @default("USD")

  shop        String?
  orderId     String? @unique
  visitorId   String?
  sessionId   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  fbclid      String?
  gclid       String?
  ttclid      String?
  msclkid     String?

  fbp         String?
  fbc         String?
  referrer    String?
  landingPage String?

  @@index([createdAt])
  @@index([shop])
  @@index([orderId])
  @@index([visitorId])
  @@index([sessionId])
  @@index([fbclid])
  @@index([gclid])
  @@index([fbc])
  @@index([fbp])
}

model AdSpendDaily {
  id        String   @id @default(cuid())
  shop      String   @default("")
  date      DateTime
  platform  String
  campaign  String?
  adset     String?
  ad        String?
  spend     Float    @default(0)

  @@unique([shop, platform, date], name: "shop_platform_date")
  @@index([shop])
  @@index([date])
  @@index([platform, date])
}

model TrackingSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  ga4Id     String?
  ga4Secret String?
  fbPixelId String?
  fbToken   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackingKey     String?  @unique
  trackingEnabled Boolean  @default(true)
  pixelLastSeenAt DateTime?
  lastEventAt     DateTime?
  installedAt     DateTime?
  uninstalledAt   DateTime?

  attributionModel      String  @default("last_touch")
  attributionWindowDays Int     @default(7)

  @@index([shop])
  @@index([trackingKey])
  @@index([trackingEnabled])
}

model MetaConnection {
  id          String   @id @default(cuid())
  shop        String   @unique
  accessToken String
  expiresAt   DateTime?
  adAccountId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop])
}

model MetaCampaignDailyInsight {
  id            String   @id @default(cuid())
  shop          String
  date          DateTime
  campaignId    String
  campaignName  String?
  spend         Float    @default(0)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  purchases     Int      @default(0)
  purchaseValue Float    @default(0)
  raw           Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, date, campaignId], name: "shop_date_campaignId")
  @@index([shop, date])
  @@index([date])
}

model MetaAdDailyInsight {
  id            String   @id @default(cuid())
  shop          String
  date          DateTime
  campaignId    String
  campaignName  String?
  adSetId       String
  adSetName     String?
  adId          String
  adName        String?
  spend         Float    @default(0)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  ctr           Float    @default(0)
  cpc           Float    @default(0)
  purchases     Int      @default(0)
  purchaseValue Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, date, adId], name: "shop_date_adId")
  @@index([shop, date])
  @@index([campaignId])
}

model GoogleConnection {
  id           String   @id @default(cuid())
  shop         String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  adCustomerId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shop])
}